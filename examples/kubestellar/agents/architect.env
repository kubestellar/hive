# /etc/hive/architect.env
#
# Architect / ideator agent — architectural RFCs, GA4-driven feature ideas,
# help-wanted grooming, cross-cutting refactor plans. Third agent alongside
# scanner (15m, GitHub triage) and reviewer (30m, post-merge state).
# Policy lives at memory/project_architect_policy.md.
# Deployed via: sudo ./install.sh --instance architect

AGENT_USER=dev
AGENT_SESSION_NAME=architect
AGENT_WORKDIR=/home/dev/kubestellar-console
AGENT_LAUNCH_CMD="/usr/bin/claude --dangerously-skip-permissions --model claude-opus-4-6"
COPILOT_CMD="/usr/bin/copilot --allow-all --model claude-opus-4-6"

# /loop cadence is 30 minutes — this is slow thoughtful work, not reactive triage.
# The real policy is in project_architect_policy.md; re-read every iteration at Step 0.
# First-task seed: start with kubestellar/console#8695 (responsive-layout RFC).
AGENT_LOOP_PROMPT="On startup, read your beads: run 'cd /home/dev/architect-beads && bd list --json' to see all open and in-progress items. Resume any in_progress item first. For new work run 'cd /home/dev/architect-beads && bd ready --json'. Claim before starting: bd update <id> --claim. At end of every pass: bd dolt push. Register: /loop 30m Follow every rule in project_architect_policy.md from memory (lane boundary, RFC structure, GA4 signal proposals, help-wanted grooming, phase-handoff to scanner). At the START of each iteration print ARCHITECT_START_ET=$(TZ=America/New_York date "+%Y-%m-%d %H:%M:%S %Z") and NEXT_ARCHITECT_ET = the next */30 firing expressed in America/New_York. At the END print ARCHITECT_END_ET and restate NEXT_ARCHITECT_ET. All timestamps MUST be in Eastern Time (America/New_York), never UTC. AFTER registering the cron, immediately run ONE kickoff iteration right now focused on kubestellar/console#8695 per the 'First task' section of the policy — produce the RFC, publish it as a comment on the GitHub issue, and file scanner-handoff beads for each phase. Do NOT wait for the first 30m firing."

AGENT_LOG_FILE=/home/dev/.claude/projects/-Users-andan02/memory/architect_log.md

AGENT_READY_MARKER="bypass permissions on"
AGENT_READY_TIMEOUT_SEC=45
AGENT_POLL_SEC=10

AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="Architect agent hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="Architect session at hive hit a quota. /login another account when convenient. 2h cadence means low urgency."

# Feature agent stalls easily (long thinking phases). More generous than scanner/reviewer.
AGENT_STALE_MAX_SEC=9000   # 2.5h — one full skipped 2h iteration + slack
AGENT_MAX_RESPAWNS=3

NTFY_TOPIC=issue-scanner

# Display persistence across respawns
AGENT_TMUX_STATUS_STYLE="bg=colour53,fg=white"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour53"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour165"
AGENT_CLAUDE_RENAME_TO=Architect
AGENT_CLI=claude
