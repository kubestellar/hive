#!/bin/bash
# Read live status from all agents
# Returns JSON with comprehensive summaries

mkdir -p ~/.hive

for agent in supervisor scanner reviewer architect outreach; do
  file=~/.hive/${agent}_status.txt
  if [ -f "$file" ]; then
    task=$(grep '^TASK=' "$file" | cut -d= -f2-)
    progress=$(grep '^PROGRESS=' "$file" | cut -d= -f2-)
    results=$(grep '^RESULTS=' "$file" | cut -d= -f2-)
    echo "  \"$agent\": {\"task\": \"$task\", \"progress\": \"$progress\", \"results\": \"$results\"}"
  else
    echo "  \"$agent\": {\"task\": \"\", \"progress\": \"\", \"results\": \"\"}"
  fi
done
